#!/usr/bin/env bash
# csk — Claude Skills Kit
# Install, manage, and toggle skill packs for Claude Code.
# https://github.com/blissun/csk
set -e

CSK_VERSION="0.1.0"
CSK_DIR="$HOME/.csk"
CSK_REGISTRY="$CSK_DIR/registry"
SKILLS_DIR="$HOME/.claude/skills"
DISABLED_DIR="$SKILLS_DIR/.csk-disabled"

mkdir -p "$CSK_DIR" "$CSK_REGISTRY" "$DISABLED_DIR"

# ─── Colors ──────────────────────────────────────────────
R="\033[0m" B="\033[1m" G="\033[32m" D="\033[90m" Y="\033[33m" C="\033[36m"

# ─── Built-in pack registry ─────────────────────────────
# Format: name|git_url|setup_cmd|description
BUILTIN_PACKS=(
  "gstack|https://github.com/garrytan/gstack.git|./setup --host claude --no-prefix|Garry's Stack — AI 엔지니어링 워크플로 (QA, 리뷰, 배포, 디자인, 브라우저)"
)

# ─── Pack registry helpers ───────────────────────────────
pack_field() {
  local pack="$1" field="$2"
  # Check built-in first
  for entry in "${BUILTIN_PACKS[@]}"; do
    IFS='|' read -r name url cmd desc <<< "$entry"
    if [ "$name" = "$pack" ]; then
      case "$field" in
        url) echo "$url" ;; cmd) echo "$cmd" ;; desc) echo "$desc" ;;
      esac
      return 0
    fi
  done
  # Check user-added registry
  if [ -f "$CSK_REGISTRY/$pack.conf" ]; then
    case "$field" in
      url)  grep '^url=' "$CSK_REGISTRY/$pack.conf" | cut -d= -f2- ;;
      cmd)  grep '^cmd=' "$CSK_REGISTRY/$pack.conf" | cut -d= -f2- ;;
      desc) grep '^desc=' "$CSK_REGISTRY/$pack.conf" | cut -d= -f2- ;;
    esac
    return 0
  fi
  return 1
}

pack_exists() { pack_field "$1" url >/dev/null 2>&1; }

installed_packs() {
  for d in "$SKILLS_DIR"/*/; do
    [ -d "$d" ] || continue
    local name="$(basename "$d")"
    [[ "$name" == .* ]] && continue
    # A pack has subdirs with SKILL.md
    local has_skills=0
    for sd in "$d"/*/; do
      [ -f "$sd/SKILL.md" ] && has_skills=1 && break
    done
    [ "$has_skills" -eq 1 ] && echo "$name"
  done | sort
}

# ─── Skills from a pack ─────────────────────────────────
pack_skills() {
  local pack="$1"
  local pd="$SKILLS_DIR/$pack"
  [ -d "$pd" ] || return
  for d in "$pd"/*/; do
    [ -f "$d/SKILL.md" ] || continue
    local b="$(basename "$d")"
    [ "$b" = "node_modules" ] && continue
    echo "$b"
  done | sort
}

all_skills() {
  while IFS= read -r pack; do
    while IFS= read -r skill; do
      echo "$pack/$skill"
    done < <(pack_skills "$pack")
  done < <(installed_packs)
}

skill_on?() { [ -L "$SKILLS_DIR/$1" ]; }


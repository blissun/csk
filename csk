# ─── Commands ────────────────────────────────────────────

cmd_install() {
  local pack="$1"
  if ! pack_exists "$pack"; then
    echo -e "  ${Y}✗${R} 팩 '$pack'을(를) 찾을 수 없습니다" >&2
    echo "  등록된 팩: $(cmd_registry | tr '\n' ' ')" >&2
    return 1
  fi

  local url; url="$(pack_field "$pack" url)"
  local cmd; cmd="$(pack_field "$pack" cmd)"
  local desc; desc="$(pack_field "$pack" desc)"
  local dest="$SKILLS_DIR/$pack"

  echo -e "\n  ${B}$pack${R} 설치 중..."
  [ -n "$desc" ] && echo -e "  ${D}$desc${R}\n"

  # Clone or update
  if [ -d "$dest/.git" ]; then
    echo "  기존 설치 발견 — 업데이트 중..."
    git -C "$dest" pull --ff-only 2>&1 | sed 's/^/  /'
  else
    [ -d "$dest" ] && rm -rf "$dest"
    git clone "$url" "$dest" 2>&1 | sed 's/^/  /'
  fi

  # Run pack setup
  if [ -n "$cmd" ]; then
    echo -e "\n  셋업 실행: ${D}$cmd${R}"
    (cd "$dest" && eval "$cmd") 2>&1 | sed 's/^/  /'
  fi

  # Count installed skills
  local count=0
  while IFS= read -r _; do count=$((count+1)); done < <(pack_skills "$pack")
  echo -e "\n  ${G}✓${R} ${B}$pack${R} 설치 완료 — ${G}$count${R}개 스킬\n"
}

cmd_uninstall() {
  local pack="$1"
  local dest="$SKILLS_DIR/$pack"
  if [ ! -d "$dest" ]; then
    echo "  ✗ '$pack'이(가) 설치되어 있지 않습니다" >&2; return 1
  fi

  # Remove symlinks
  while IFS= read -r skill; do
    [ -L "$SKILLS_DIR/$skill" ] && rm -f "$SKILLS_DIR/$skill"
    rm -f "$DISABLED_DIR/$skill"
  done < <(pack_skills "$pack")

  rm -rf "$dest"
  echo -e "  ${G}✓${R} ${B}$pack${R} 제거 완료"
}

cmd_update() {
  local pack="${1:-}"
  if [ -z "$pack" ]; then
    while IFS= read -r p; do cmd_install "$p"; done < <(installed_packs)
  else
    cmd_install "$pack"
  fi
}

cmd_ls() {
  local packs; packs="$(installed_packs)"
  if [ -z "$packs" ]; then
    echo -e "\n  설치된 팩이 없습니다. ${D}csk install gstack${R} 으로 시작하세요\n"
    return
  fi

  while IFS= read -r pack; do
    local t=0 e=0 d=0
    printf "\n  ${B}[%s]${R}\n" "$pack"
    while IFS= read -r s; do
      t=$((t+1))
      if skill_on? "$s"; then
        e=$((e+1)); printf "  %-28s ${G}● ON${R}\n" "$s"
      else
        d=$((d+1)); printf "  %-28s ${D}○ OFF${R}\n" "$s"
      fi
    done < <(pack_skills "$pack")
    printf "  ${D}— %d개 스킬 | ON: %d | OFF: %d${R}\n" "$t" "$e" "$d"
  done <<< "$packs"
  echo
}

cmd_on() {
  local skill="$1" found=0
  if [ "$skill" = "all" ]; then
    while IFS= read -r pack; do
      while IFS= read -r s; do cmd_on_single "$pack" "$s"; done < <(pack_skills "$pack")
    done < <(installed_packs)
    return
  fi
  # Find which pack owns this skill
  while IFS= read -r pack; do
    if [ -d "$SKILLS_DIR/$pack/$skill" ] && [ -f "$SKILLS_DIR/$pack/$skill/SKILL.md" ]; then
      cmd_on_single "$pack" "$skill"; found=1; break
    fi
  done < <(installed_packs)
  if [ "$found" -eq 0 ]; then echo "  ✗ '$skill' not found" >&2; return 1; fi
}

cmd_on_single() {
  local pack="$1" skill="$2"
  if skill_on? "$skill"; then echo "  $skill — already ON"; return; fi
  ln -snf "$pack/$skill" "$SKILLS_DIR/$skill"
  rm -f "$DISABLED_DIR/$skill"
  echo "  $skill → ON"
}

cmd_off() {
  local skill="$1" found=0
  if [ "$skill" = "all" ]; then
    while IFS= read -r pack; do
      while IFS= read -r s; do cmd_off_single "$s"; done < <(pack_skills "$pack")
    done < <(installed_packs)
    return
  fi
  while IFS= read -r pack; do
    if [ -d "$SKILLS_DIR/$pack/$skill" ] && [ -f "$SKILLS_DIR/$pack/$skill/SKILL.md" ]; then
      cmd_off_single "$skill"; found=1; break
    fi
  done < <(installed_packs)
  if [ "$found" -eq 0 ]; then echo "  ✗ '$skill' not found" >&2; return 1; fi
}

cmd_off_single() {
  local skill="$1"
  skill_on? "$skill" || { echo "  $skill — already OFF"; return; }
  rm -f "$SKILLS_DIR/$skill"
  touch "$DISABLED_DIR/$skill"
  echo "  $skill → OFF"
}

cmd_help_one() {
  local skill="$1" found=0
  while IFS= read -r pack; do
    if [ -d "$SKILLS_DIR/$pack/$skill" ]; then
      found=1
      local st; skill_on? "$skill" && st="${G}● ON${R}" || st="${D}○ OFF${R}"
      printf "\n  ${B}/%s${R}  %b  ${D}(%s)${R}\n" "$skill" "$st" "$pack"
      local ko; ko="$(help_ko "$skill")"
      if [ -n "$ko" ]; then
        printf "  %s\n\n" "$ko"
      else
        sed -n '/^description:/,/^[a-z]*:/{s/^description:[[:space:]]*//p;s/^  //p;}' \
          "$SKILLS_DIR/$pack/$skill/SKILL.md" 2>/dev/null | head -2 | while read -r l; do printf "  %s\n" "$l"; done
        printf "\n"
      fi
      break
    fi
  done < <(installed_packs)
  if [ "$found" -eq 0 ]; then echo "  ✗ '$skill' not found" >&2; return 1; fi
}

cmd_help_all() {
  while IFS= read -r pack; do
    printf "\n  ${B}[%s]${R}\n\n" "$pack"
    while IFS= read -r s; do
      local st; skill_on? "$s" && st="${G}●${R}" || st="${D}○${R}"
      local desc; desc="$(help_ko "$s")"
      if [ -z "$desc" ]; then
        desc=$(sed -n '/^description:/{ s/^description:[[:space:]]*//; p; q; }' \
          "$SKILLS_DIR/$pack/$s/SKILL.md" 2>/dev/null)
      fi
      printf "  %b %-24s %s\n" "$st" "$s" "${desc:-(설명 없음)}"
    done < <(pack_skills "$pack")
  done < <(installed_packs)
  echo
}

cmd_packs() {
  printf "\n  ${B}설치된 팩${R}\n\n"
  local has=0
  while IFS= read -r pack; do
    has=1
    local count=0
    while IFS= read -r _; do count=$((count+1)); done < <(pack_skills "$pack")
    local desc; desc="$(pack_field "$pack" desc 2>/dev/null || echo "")"
    printf "  ${G}●${R} %-20s ${D}%d개 스킬${R}" "$pack" "$count"
    [ -n "$desc" ] && printf "  ${D}— %s${R}" "$desc"
    printf "\n"
  done < <(installed_packs)
  [ "$has" -eq 0 ] && echo -e "  (없음) — ${D}csk install gstack${R} 으로 시작"

  printf "\n  ${B}등록된 팩${R}\n\n"
  for entry in "${BUILTIN_PACKS[@]}"; do
    IFS='|' read -r name url cmd desc <<< "$entry"
    if [ -d "$SKILLS_DIR/$name" ]; then
      printf "  ${G}●${R} %-20s ${D}%s${R}\n" "$name" "$desc"
    else
      printf "  ${D}○${R} %-20s ${D}%s${R}\n" "$name" "$desc"
    fi
  done
  for f in "$CSK_REGISTRY"/*.conf; do
    [ -f "$f" ] || continue
    local name="$(basename "$f" .conf)"
    local desc; desc="$(grep '^desc=' "$f" | cut -d= -f2-)"
    if [ -d "$SKILLS_DIR/$name" ]; then
      printf "  ${G}●${R} %-20s ${D}%s${R}\n" "$name" "$desc"
    else
      printf "  ${D}○${R} %-20s ${D}%s${R}\n" "$name" "$desc"
    fi
  done
  echo
}

cmd_add_pack() {
  local name="$1" url="$2" setup="${3:-}" desc="${4:-}"
  if [ -z "$name" ] || [ -z "$url" ]; then
    echo "csk add <name> <git-url> [setup-cmd] [description]" >&2; return 1
  fi
  cat > "$CSK_REGISTRY/$name.conf" <<EOF
url=$url
cmd=$setup
desc=$desc
EOF
  echo -e "  ${G}✓${R} 팩 '${B}$name${R}' 등록 완료"
  echo -e "  ${D}csk install $name${R} 으로 설치하세요"
}

cmd_gui() {
  local gui_bin="$HOME/.csk/bin/CSK"

  # Try pre-built binary first
  if [ -x "$gui_bin" ]; then
    "$gui_bin" &
    echo -e "  ${G}✓${R} GUI 실행"
    return
  fi

  # Find source: check known locations
  local gui_src=""
  for d in "$HOME/Documents/Github/csk/gui/CSK" "$HOME/.csk/src/gui/CSK"; do
    [ -f "$d/Package.swift" ] && gui_src="$d" && break
  done

  if [ -n "$gui_src" ] && command -v swift >/dev/null 2>&1; then
    echo -e "  ${D}GUI 빌드 중...${R}"
    (cd "$gui_src" && swift build -c release 2>&1 | tail -1)
    local built="$gui_src/.build/release/CSK"
    if [ -x "$built" ]; then
      mkdir -p "$HOME/.csk/bin"
      cp "$built" "$gui_bin"
      "$gui_bin" &
      echo -e "  ${G}✓${R} GUI 실행"
      return
    fi
  fi

  echo -e "  ${Y}!${R} GUI 바이너리를 찾을 수 없습니다" >&2
  echo -e "  ${D}swift build 후 ~/.csk/bin/CSK 에 복사하세요${R}" >&2
}

cmd_version() { echo "csk $CSK_VERSION"; }

cmd_usage() {
  echo -e "
  ${B}csk${R} — Claude Skills Kit v$CSK_VERSION

  ${B}팩 관리${R}
    csk install <pack>       스킬팩 설치
    csk uninstall <pack>     스킬팩 제거
    csk update [pack]        업데이트 (전체 또는 특정 팩)
    csk packs                등록/설치된 팩 목록
    csk add <n> <url> [cmd]  커스텀 팩 등록

  ${B}스킬 관리${R}
    csk ls                   전체 스킬 상태
    csk on <skill|all>       스킬 켜기
    csk off <skill|all>      스킬 끄기
    csk t <skill>            토글

  ${B}GUI${R}
    csk gui                  SwiftUI 앱 실행

  ${B}도움말${R}
    csk help [skill|all]     스킬 설명 (한글)
    csk -v                   버전
"
}

# ─── Main ────────────────────────────────────────────────
case "${1:-}" in
  install|i)     [ -z "$2" ] && echo "csk install <pack>" >&2 && exit 1; cmd_install "$2" ;;
  uninstall|rm)  [ -z "$2" ] && echo "csk uninstall <pack>" >&2 && exit 1; cmd_uninstall "$2" ;;
  update|up)     cmd_update "${2:-}" ;;
  packs|p)       cmd_packs ;;
  add)           cmd_add_pack "${2:-}" "${3:-}" "${4:-}" "${5:-}" ;;
  ls|list)       cmd_ls ;;
  on|enable)     [ -z "$2" ] && echo "csk on <skill|all>" >&2 && exit 1; cmd_on "$2" ;;
  off|disable)   [ -z "$2" ] && echo "csk off <skill|all>" >&2 && exit 1; cmd_off "$2" ;;
  t|toggle)      [ -z "$2" ] && echo "csk t <skill>" >&2 && exit 1
                 if skill_on? "$2"; then cmd_off "$2"; else cmd_on "$2"; fi ;;
  h|help)        if [ -z "$2" ] || [ "$2" = "all" ]; then cmd_help_all; else cmd_help_one "$2"; fi ;;
  gui)           cmd_gui ;;
  -v|--version)  cmd_version ;;
  -h|--help|"")  cmd_usage ;;
  *)             echo -e "  ${Y}?${R} 알 수 없는 명령: $1\n" >&2; cmd_usage >&2; exit 1 ;;
esac
